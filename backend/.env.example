# ===========================================
# VEZORA AI - BACKEND CONFIGURATION
# ===========================================

# ===========================================
# 1. SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ===========================================
# 2. AI PROVIDER CONFIGURATION
# ===========================================

# Primary AI Provider: gemini | ollama | auto
AI_PROVIDER=ollama

# --- Gemini AI (Google) ---
GEMINI_API_KEY=your_existing_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash-latest

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=mistral:latest

# ===========================================
# 3. GOOGLE OAUTH 2.0 (Gmail & Calendar)
# ===========================================

# Paste your credentials from Google Cloud Console here:
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# OAuth Token Storage (will be auto-generated)
GOOGLE_TOKENS_FILE=./data/google-tokens.json

# ===========================================
# 4. WEB SEARCH API (Choose ONE)
# ===========================================

# Option A: SerpAPI (Recommended - easiest)
# Sign up: https://serpapi.com/ (100 free searches/month)
SERPAPI_KEY=

# Option B: Google Custom Search (Free, limited)
# Get key: https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Option C: Use Gemini with Grounding (uses GEMINI_API_KEY above)
ENABLE_GEMINI_GROUNDING=false

# ===========================================
# 5. GOOGLE CLOUD TTS (OPTIONAL)
# ===========================================
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_PROJECT_ID=

# ===========================================
# 6. WAKE WORD DETECTION (OPTIONAL)
# ===========================================

# Picovoice Porcupine: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=

# ===========================================
# 7. FEATURE TOGGLES
# ===========================================
VOICE_CALL_MODE=true
ENABLE_APP_LAUNCH=true
ENABLE_FILE_SYSTEM=true
ENABLE_GMAIL=true
ENABLE_CALENDAR=true
ENABLE_WEB_SEARCH=true
ENABLE_WORKFLOWS=true

# ===========================================
# 8. SECURITY & ENCRYPTION
# ===========================================

# Encryption key for database (change this!)
ENCRYPTION_KEY=vezora-2026-secure-encryption-key-change-this-to-random-32chars

# SQLCipher password (for encrypted database)
SQLCIPHER_PASSWORD=your-secure-database-password-here

# Max storage limits
MAX_MEMORY_ITEMS=100
MAX_LOG_ENTRIES=500

# ===========================================
# 9. DATA STORAGE PATHS
# ===========================================
DATA_DIR=./data
MEMORY_FILE=./data/memory.json
SETTINGS_FILE=./data/settings.json
LOGS_FILE=./data/logs.json

# Database (SQLite with encryption)
DATABASE_PATH=./data/vezora.db